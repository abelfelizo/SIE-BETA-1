  "motores": {
    "totales": 23,
    "existentes": 18,
    "nuevos": 5,
    
    "nuevos_motores": {
      "M_Pivot": {
        "nombre": "Motor Pivot Electoral",
        "funcion": "Identifica provincias que deciden la elección",
        "referencia": "Jacobson 2004",
        "implementacion": "engine.js"
      },
      "M_Ruta": {
        "nombre": "Motor Ruta de Victoria",
        "funcion": "Calcula combinaciones mínimas para ganar",
        "algoritmo": "Subset optimization (greedy)",
        "implementacion": "engine.js"
      },
      "M_Meta": {
        "nombre": "Motor Meta Electoral",
        "funcion": "Proyecta meta de votos para 2028",
        "referencia": "Leighley-Nagler 2013",
        "implementacion": "engine.js"
      },
      "M_Prioridad": {
        "nombre": "Motor Prioridad Estratégica",
        "funcion": "Ranking de inversión por provincia",
        "ponderacion": "pivot(40%) + gap(30%) + probabilidad(30%)",
        "implementacion": "engine.js"
      },
      "M17_v9": {
        "nombre": "Motor Normalización Histórica (ACTIVADO)",
        "funcion": "Ajusta proyecciones por madurez organizativa",
        "referencia": "Panebianco 1988",
        "formula": "factor = (años/8) × (ratio_votos)^0.5",
        "estado": "ACTIVE",
        "implementacion": "engine.js"
      }
    }
  },

  "estructura_archivos": {
    "core": {
